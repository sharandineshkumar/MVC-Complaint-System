<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Citizen Complaint Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <div class="top-strip">
        Government of India &nbsp;|&nbsp; Official Citizen Services Portal
    </div>

    <div class="gov-header">
        <div class="container">
            <div class="d-flex align-items-center">
                <div class="gov-emblem">CS</div>
                <div>
                    <div class="portal-title">Citizen Complaint Management Portal</div>
                    <div class="portal-subtitle">Ministry of Public Grievances &amp; Administration</div>
                </div>
            </div>
        </div>
    </div>

    <nav class="gov-navbar">
        <div class="container">
            <ul class="nav">
                @if (User.Identity.IsAuthenticated)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Complaints" asp-action="Index">All Complaints</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Complaints" asp-action="Create">Submit Complaint</a>
                    </li>
                    <li class="nav-item ms-auto">
                        <span class="user-info">Logged in as: @User.Identity.Name</span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Logout">Logout</a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                    </li>
                }
            </ul>
        </div>
    </nav>

    <div class="main-content">
        <div class="container">
            @RenderBody()
        </div>
    </div>

    <!-- Toast notification container — shown only to Admin -->
    @if (User.IsInRole("Admin"))
    {
        <div style="position:fixed; top:20px; right:20px; z-index:9999; min-width:300px;">
            <div id="notificationToast" class="toast align-items-center text-white bg-primary border-0 hide"
                 role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body" id="toastMessage">
                        New complaint received.
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <footer class="gov-footer">
        <div class="container">
            &copy; @DateTime.Now.Year — Citizen Complaint Portal &nbsp;|&nbsp; All Rights Reserved &nbsp;|&nbsp; Government of India
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    <!-- SignalR script — only load for Admin -->
    @if (User.IsInRole("Admin"))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script>
            // Connect to the hub
            var connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

            // When server sends a notification, show the toast
            connection.on("ReceiveNotification", function (message) {
            document.getElementById("toastMessage").innerText = message;

            var toastEl = document.getElementById("notificationToast");
            var toast = new bootstrap.Toast(toastEl, { delay: 6000 });
            toast.show();
            });

            // Start the connection
            connection.start().catch(function (err) {
            console.error("SignalR connection error: " + err.toString());
            });
        </script>
    }

</body>
</html>